{
     "hosting": [
          {
               "site": "buddha-nature",
               "public": "dist",
               "predeploy": [
                    "bun run build"
               ],
               "ignore": [
                    "firebase.json",
                    "**/.*",
                    "**/node_modules/**"
               ],
               "headers": [
                    {
                         "source": "/sitemap.xml",
                         "headers": [
                              {
                                   "key": "Content-Type",
                                   "value": "application/xml; charset=utf-8"
                              },
                              {
                                   "key": "Cache-Control",
                                   "value": "public, max-age=3600"
                              }
                         ]
                    },
                    {
                         "source": "/manifest.json",
                         "headers": [
                              {
                                   "key": "Cache-Control",
                                   "value": "public, max-age=3600"
                              }
                         ]
                    },
                    {
                         "source": "**/*.pdf",
                         "headers": [
                              {
                                   "key": "Content-Type",
                                   "value": "application/pdf"
                              }
                         ]
                    },
                    {
                         "source": "/sw.js",
                         "headers": [
                              {
                                   "key": "Cache-Control",
                                   "value": "no-cache, no-store, must-revalidate"
                              },
                              {
                                   "key": "Pragma",
                                   "value": "no-cache"
                              },
                              {
                                   "key": "Expires",
                                   "value": "0"
                              }
                         ]
                    },
                    {
                         "source": "**/*.{js,css,woff2,woff,ttf,eot,svg,png,jpg,jpeg,gif,webp,ico,json}",
                         "headers": [
                              {
                                   "key": "Cache-Control",
                                   "value": "public, max-age=31536000, immutable"
                              }
                         ]
                    },
                    {
                         "source": "/index.html",
                         "headers": [
                              {
                                   "key": "Cache-Control",
                                   "value": "no-cache, no-store, must-revalidate"
                              }
                         ]
                    }
               ],
               "rewrites": [
                    {
                         "source": "/sitemap.xml",
                         "destination": "/sitemap.xml"
                    },
                    {
                         "source": "/robots.txt",
                         "destination": "/robots.txt"
                    },
                    {
                         "source": "**",
                         "destination": "/index.html"
                    }
               ],
               "environment": {
                    "ENV_MODE": "production"
               }
          }
     ]
}